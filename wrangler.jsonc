{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "my9",
  "main": "worker.js",
  "compatibility_date": "2026-03-14",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "preview_urls": true,
  "routes": [
    {
      "pattern": "my9.shatranj.space",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "logs": {
      "enabled": true,
      "head_sampling_rate": 0.2,
      "invocation_logs": true
    },
    "traces": {
      "enabled": false
    }
  },
  "triggers": {
    "crons": ["5 16 * * *"]
  },
  "vars": {
    "MY9_SHARE_VIEW_ANALYTICS_DATASET": "my9_share_views_v1"
  },
  "analytics_engine_datasets": [
    {
      "binding": "MY9_SHARE_VIEW_ANALYTICS",
      "dataset": "my9_share_views_v1"
    }
  ],
  "env": {
    "test": {
      "routes": [
        {
          "pattern": "my9test.shatranj.space",
          "custom_domain": true
        }
      ],
      "vars": {
        "MY9_SHARE_VIEW_ANALYTICS_DATASET": "my9_share_views_test_v1"
      },
      "analytics_engine_datasets": [
        {
          "binding": "MY9_SHARE_VIEW_ANALYTICS",
          "dataset": "my9_share_views_test_v1"
        }
      ],
      "assets": {
        "directory": ".open-next/assets",
        "binding": "ASSETS"
      },
      "triggers": {
        "crons": []
      }
    }
  }
}
